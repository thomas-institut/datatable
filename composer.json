{
    "name": "thomas-institut/datatable",
    "type": "library",
    "description": "A simple data table interface",
    "keywords": ["data"],
    "license": "MIT",
    "authors": [
        {
            "name": "Rafael Nájera",
            "email": "rafael@najera.ca",
            "homepage": "https://rafaelnajera.com"
        }
    ],
    "scripts" : {
        "test": "./vendor/bin/phpunit test --display-all-issues",
        "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit test --display-all-issues --coverage-filter DataTable --coverage-text --coverage-html build/coverage"
    },
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "psr/log": "^3.0",
        "thomas-institut/timestring": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "monolog/monolog": "^3.10",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "ThomasInstitut\\DataTable\\": "DataTable"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThomasInstitut\\DataTable\\": "test",
            "ThomasInstitut\\DataTable\\Test\\": "test/MockClasses"
        }
    }
}
